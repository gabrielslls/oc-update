#!/bin/bash
#
# oc-update - Manage OpenCode and Oh-My-OpenCode updates
#
# Usage:
#   oc-update check [--oc|--omo]     # Check for updates (prompt to update)
#   oc-update update [--oc|--omo]    # Update directly without prompt
#   oc-update disable [oc|omo|all]   # Disable auto-update
#   oc-update enable [oc|omo|all]    # Enable auto-update
#   oc-update config                 # Show current config
#   oc-update --help                 # Show help
#

# 强制使用bash执行检测
if [ -z "$BASH_VERSION" ]; then
    echo "❌ 错误：此脚本必须使用bash运行，请执行：bash $0 $*" >&2
    exit 1
fi

# 全局错误捕获
trap 'echo -e "\n${RED}❌ 执行错误${NC}：行号 $LINENO，命令：$BASH_COMMAND，返回码：$?" >&2; exit 1' ERR

set -euo pipefail

# ============================================
# 自动添加包管理器全局bin路径到脚本内部PATH（不修改用户环境）
# ============================================
add_global_paths_to_path() {
    local paths=()
    
    # pnpm 路径
    if [[ -z "${PNPM_HOME:-}" ]]; then
        PNPM_HOME="$HOME/.local/share/pnpm"
    fi
    [[ -d "$PNPM_HOME" ]] && paths+=("$PNPM_HOME")
    
    # npm 全局bin路径
    if command -v npm &>/dev/null; then
        local npm_bin
        # 兼容新旧版本npm
        npm_bin=$(npm bin -g 2>/dev/null || npm config get prefix 2>/dev/null | sed 's/$/\/bin/')
        [[ -d "$npm_bin" ]] && paths+=("$npm_bin")
    fi
    
    # yarn 全局bin路径
    if command -v yarn &>/dev/null; then
        local yarn_bin
        yarn_bin=$(yarn global bin 2>/dev/null)
        [[ -d "$yarn_bin" ]] && paths+=("$yarn_bin")
    fi
    
    # bun 全局bin路径
    [[ -d "$HOME/.bun/bin" ]] && paths+=("$HOME/.bun/bin")
    
    # 去重并添加到PATH开头
    local new_path=""
    local IFS=':'
    for p in ${paths[*]} $PATH; do
        if [[ ! ":$new_path:" =~ ":$p:" ]]; then
            new_path="${new_path:+$new_path:}$p"
        fi
    done
    unset IFS
    
    export PATH="$new_path"
}

# 执行路径添加
add_global_paths_to_path

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# 全局网络配置（适配国内环境）
# npm镜像配置，默认使用淘宝源，支持环境变量覆盖
NPM_REGISTRY="${NPM_REGISTRY:-https://registry.npmmirror.com}"
# GitHub代理配置，默认使用最快的gh.llkk.cc，支持环境变量覆盖
GITHUB_PROXY="${GITHUB_PROXY:-https://gh.llkk.cc/}"
# 备用npm镜像源，用于fallback
NPM_REGISTRIES=(
    "https://registry.npmmirror.com"
    "https://mirrors.ustc.edu.cn/npm"
    "https://registry.npmjs.org"
)

# 系统架构检测
ARCH="$(uname -m | tr '[:upper:]' '[:lower:]')"
IS_AARCH64="false"
if [[ "$ARCH" == "aarch64" || "$ARCH" == "arm64" ]]; then
    IS_AARCH64="true"
fi



# Package info
OC_PKG="opencode-ai"
# OMO官方npm包名是 oh-my-opencode
OMO_PKG_OLD="oh-my-opencode"
OMO_PKG_NEW=""
OMO_PKG="$OMO_PKG_OLD"
OC_NAME="OpenCode"
OMO_NAME="Oh-My-OpenCode"
OC_REPO="anomaly/opencode"
OMO_REPO="code-yeongyu/oh-my-openagent"

# Config paths
CONFIG_DIR="$HOME/.config/opencode"
OC_CONFIG="$CONFIG_DIR/opencode.json"
OMO_CONFIG="$CONFIG_DIR/oh-my-opencode.json"

# Version
VERSION="1.5.0"

# Flags
CHECK_OC=true
CHECK_OMO=true

# 初始化相关变量，避免set -u未绑定错误
OC_NOT_IN_PATH=${OC_NOT_IN_PATH:-}
OC_PKG_FOUND=${OC_PKG_FOUND:-}
OMO_NOT_IN_PATH=${OMO_NOT_IN_PATH:-}
OMO_PKG_FOUND=${OMO_PKG_FOUND:-}
REMOTE_FETCH_FAILED=${REMOTE_FETCH_FAILED:-}

# ============================================
# Utilities
# ============================================

log_debug() {
    # 默认不输出debug信息，需要时设置DEBUG=true环境变量
    if [[ "${DEBUG:-false}" == "true" ]]; then
        echo -e "\033[0;34m[DEBUG]\033[0m $*" >&2
    fi
}

# 通用GitHub资源请求函数，自动走代理重试
get_url() {
    local url="$1"
    local output="${2:-}"
    # 用户提供的代理列表，按实测速度优先级排序（2026-04-21实测）
    local mirrors=("gh.llkk.cc|https://" "gh-proxy.com|https://" "git.yylx.win|https://" "fastgit.cc|" "ghproxy.net|https://")
    
    for mirror_config in "${mirrors[@]}"; do
        local mirror="${mirror_config%%|*}"
        local prefix="${mirror_config##*|}"
        local req_url
        
        # 适配fastgit.cc特殊格式：不需要https://前缀
        if [[ "$mirror" == "fastgit.cc" ]]; then
            req_url="https://${mirror}/${url#https://}"
        else
            req_url="https://${mirror}/${prefix}${url#https://}"
        fi
        
        log_debug "尝试通过代理 ${mirror} 访问: ${req_url}"
        # 30秒超时尝试
        if curl -s --max-time 30 --fail "$req_url" ${output:+-o "$output"}; then
            log_debug "代理 ${mirror} 访问成功"
            return 0
        fi
    done
    
    # 所有代理失败最后尝试直连
    log_debug "所有代理失败，尝试直连: ${url}"
    curl -s --max-time 30 --fail "$url" ${output:+-o "$output"} && return 0
    
    log_debug "所有访问方式均失败"
    return 1
}

check_deps() {
    local missing=()
    # 不需要强制npm，因为可以走手动安装fallback
    # 手动安装需要curl和tar
    command -v curl &> /dev/null || missing+=("curl")
    command -v tar &> /dev/null || missing+=("tar")
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}错误: 缺少必要依赖: ${missing[*]}${NC}"
        echo "请安装上述工具后再运行 $0"
        exit 1
    fi
}

# 带重试和超时的命令执行工具
# 用法: run_with_retry [--retries N] [--timeout SECONDS] [--no-fail] COMMAND
# 选项:
#   --retries N: 最大重试次数，默认3
#   --timeout SECONDS: 命令执行超时时间，默认20
#   --no-fail: 即使所有重试失败也不返回错误，返回空
run_with_retry() {
    local retries=3
    local timeout=20
    local no_fail=false
    
    # 解析选项
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --retries) retries="$2"; shift 2 ;;
            --timeout) timeout="$2"; shift 2 ;;
            --no-fail) no_fail=true; shift ;;
            *) break ;;
        esac
    done
    
    local cmd="$*"
    local timeout_prefix=""
    if command -v timeout >/dev/null; then
        timeout_prefix="timeout -k 3s ${timeout}s"
    fi
    
    for ((attempt=0; attempt<retries; attempt++)); do
        log_debug "  命令执行尝试 $((attempt+1))/$retries：$cmd"
        # 实时输出日志，方便用户查看进度
        eval "$timeout_prefix $cmd" 2>&1
        local exit_code=$?
        if [[ $exit_code -eq 0 ]]; then
            return 0
        fi
        log_debug "  尝试 $((attempt+1)) 失败，退出码：$exit_code"
        [[ $attempt -lt $((retries-1)) ]] && sleep 1
    done
    
    log_debug "  所有 $retries 次尝试均失败"
    if [[ "$no_fail" == false ]]; then
        return 1
    else
        return 0
    fi
}

has_jq() {
    command -v jq &> /dev/null
}


get_oc_autoupdate() {
    if [[ -f "$OC_CONFIG" ]]; then
        if has_jq; then
            jq -r '.autoupdate // false' "$OC_CONFIG" 2>/dev/null
        else
            grep -o '"autoupdate"[[:space:]]*:[[:space:]]*[^,}]*' "$OC_CONFIG" 2>/dev/null | \
                sed 's/.*:[[:space:]]*//' | tr -d ' ",' | head -1
        fi
    else
        echo "not-found"
    fi
}

get_omo_auto_update() {
    if [[ -f "$OMO_CONFIG" ]]; then
        if has_jq; then
            jq -r '.auto_update // false' "$OMO_CONFIG" 2>/dev/null
        else
            grep -o '"auto_update"[[:space:]]*:[[:space:]]*[^,}]*' "$OMO_CONFIG" 2>/dev/null | \
                sed 's/.*:[[:space:]]*//' | tr -d ' ",' | head -1
        fi
    else
        echo "not-found"
    fi
}

is_omo_hook_disabled() {
    if [[ -f "$OMO_CONFIG" ]]; then
        if has_jq; then
            jq -e '.disabled_hooks[] | select(. == "auto-update-checker")' "$OMO_CONFIG" &>/dev/null
            return $?
        else
            grep -q '"auto-update-checker"' "$OMO_CONFIG" 2>/dev/null
            return $?
        fi
    fi
    return 1
}

set_oc_autoupdate() {
    local value="$1"
    [[ ! -f "$OC_CONFIG" ]] && { echo -e "${RED}✗ 配置文件不存在: $OC_CONFIG${NC}"; return 1; }
    if has_jq; then
        local tmp; tmp=$(mktemp)
        jq --arg v "$value" '.autoupdate = ($v | if $v == "true" then true elif $v == "false" then false else $v end)' \
            "$OC_CONFIG" > "$tmp" && mv "$tmp" "$OC_CONFIG"
    else
        sed -i "s/\"autoupdate\"[[:space:]]*:[[:space:]]*[^,}]*/\"autoupdate\": $value/" "$OC_CONFIG"
    fi
}

set_omo_auto_update() {
    local value="$1"
    [[ ! -f "$OMO_CONFIG" ]] && { echo -e "${RED}✗ 配置文件不存在: $OMO_CONFIG${NC}"; return 1; }
    if has_jq; then
        local tmp; tmp=$(mktemp)
        jq --argjson v "$value" '.auto_update = $v' "$OMO_CONFIG" > "$tmp" && mv "$tmp" "$OMO_CONFIG"
    else
        sed -i "s/\"auto_update\"[[:space:]]*:[[:space:]]*[^,}]*/\"auto_update\": $value/" "$OMO_CONFIG"
    fi
}

add_omo_disabled_hook() {
    [[ ! -f "$OMO_CONFIG" ]] && return 1
    is_omo_hook_disabled && return 0
    if has_jq; then
        local tmp; tmp=$(mktemp)
        jq '.disabled_hooks = (.disabled_hooks // []) + ["auto-update-checker"]' "$OMO_CONFIG" > "$tmp" && mv "$tmp" "$OMO_CONFIG"
    else
        sed -i 's/"disabled_hooks"[[:space:]]*:[[:space:]]*\[/&"auto-update-checker", /' "$OMO_CONFIG"
    fi
}

remove_omo_disabled_hook() {
    [[ ! -f "$OMO_CONFIG" ]] && return 1
    if has_jq; then
        local tmp; tmp=$(mktemp)
        jq '.disabled_hooks = [.disabled_hooks[] | select(. != "auto-update-checker")]' "$OMO_CONFIG" > "$tmp" && mv "$tmp" "$OMO_CONFIG"
    else
        sed -i 's/"auto-update-checker"[[:space:]]*,[[:space:]]*//' "$OMO_CONFIG"
        sed -i 's/,[[:space:]]*"auto-update-checker"//' "$OMO_CONFIG"
    fi
}

is_oc_disabled() {
    local val; val=$(get_oc_autoupdate)
    [[ "$val" == "false" ]] || [[ -n "${OPENCODE_DISABLE_AUTOUPDATE:-}" ]]
}

is_omo_disabled() {
    local val; val=$(get_omo_auto_update)
    [[ "$val" == "false" ]] || is_omo_hook_disabled
}

# ============================================
# Version operations
# ============================================

# 检测包管理器类型
detect_package_manager() {
    local pkg="$1"
    log_debug "开始检测$pkg对应的包管理器..."
    log_debug "开始检测$pkg对应的包管理器..."
    # OMO特殊处理：尝试新旧包名
    local pkgs_to_check=("$pkg")
    [[ "$pkg" == "$OMO_PKG_NEW" ]] && pkgs_to_check+=("$OMO_PKG_OLD")
    
    # 验证包管理器是否可用
    validate_pm() {
        local pm="$1"
        case "$pm" in
            pnpm) command -v pnpm &>/dev/null && pnpm --version &>/dev/null ;;
            yarn) command -v yarn &>/dev/null && yarn --version &>/dev/null ;;
            bun) command -v bun &>/dev/null && bun --version &>/dev/null ;;
            npm) command -v npm &>/dev/null && npm --version &>/dev/null ;;
            *) return 1 ;;
        esac
        return $?
    }
    
    # 检测npm版本，返回主版本号
    get_npm_version() {
        if command -v npm &>/dev/null; then
            npm --version | cut -d. -f1
        else
            echo 0
        fi
    }
    
    for p in "${pkgs_to_check[@]}"; do
        # 按照优先级检查包管理器
        for pm in "${PM_PRIORITY[@]}"; do
            if command -v "$pm" &>/dev/null; then
                # 检查当前包管理器是否安装了目标包
                local found=false
                case "$pm" in
                    pnpm)
                        if pnpm list -g "$p" 2>/dev/null | grep -qE "(pnpm:|$p@)"; then
                            found=true
                        fi
                        ;;
                    yarn)
                        if yarn global list --pattern "$p" 2>/dev/null | grep -q "$p"; then
                            found=true
                        fi
                        ;;
                    npm)
                        # aarch64下npm版本低于8.x的话，不优先使用
                        if [[ "$IS_AARCH64" == "true" && $(get_npm_version) -lt 8 ]]; then
                            log_debug "aarch64环境下npm版本过低（<8.x），跳过使用"
                            continue
                        fi
                        if npm list -g "$p" 2>/dev/null | grep -q "$p@"; then
                            found=true
                        fi
                        ;;
                esac
                
                if [[ "$found" == "true" ]]; then
                    validate_pm "$pm" && echo "$pm" && return
                fi
            fi
        done
        
        # 检查bun环境（优先级最低）
        if command -v bun &>/dev/null && [[ -f "$HOME/.bun/install/global/node_modules/$p/package.json" ]]; then
            validate_pm bun && echo "bun" && return
        fi
    done
    
    # 如果都没检测到，优先检测当前实际运行命令的安装来源
    local cmd_name=""
    [[ "$pkg" == "opencode-ai" ]] && cmd_name="opencode"
    [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]] && cmd_name="omo"
    
    if [[ -n "$cmd_name" ]]; then
        local cmd_path=$(command -v "$cmd_name" 2>/dev/null)
        if [[ -n "$cmd_path" ]]; then
            # 解析符号链接判断来源
            if [[ "$cmd_path" == *pnpm* || "$cmd_path" == *".local/share/pnpm"* ]]; then
                command -v pnpm &>/dev/null && validate_pm pnpm && echo "pnpm" && return
            elif [[ "$cmd_path" == *bun* || "$cmd_path" == *".bun/bin"* ]]; then
                command -v bun &>/dev/null && validate_pm bun && echo "bun" && return
            elif [[ "$cmd_path" == *yarn* ]]; then
                command -v yarn &>/dev/null && validate_pm yarn && echo "yarn" && return
            fi
        fi
    fi
    
    # 最后兜底：返回当前系统优先的包管理器
    if command -v pnpm &>/dev/null && validate_pm pnpm; then
        echo "pnpm"
    else
        echo "npm"
    fi
}

# 查找包的实际安装路径
find_package_path() {
    local pkg="$1"
    log_debug "开始查找$pkg的安装路径..."
    local found_path=""
    
    # 方法 1: 通过命令路径反推（优先级最高，这是实际运行的版本）
    local cmd_name=""
    local full_cmd_name=""
    [[ "$pkg" == "opencode-ai" ]] && cmd_name="opencode"
    [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]] && cmd_name="omo" && full_cmd_name="oh-my-opencode"
    
    # 先尝试短命令
    if [[ -n "$cmd_name" ]]; then
        log_debug "尝试通过短命令$cmd_name查找路径..."
        local cmd_path=$(command -v "$cmd_name" 2>/dev/null)
        log_debug "短命令$cmd_name路径：${cmd_path:-未找到}"
        if [[ -n "$cmd_path" ]]; then
            # 如果是符号链接，解析到真实路径
            if [[ -L "$cmd_path" ]]; then
                log_debug "解析符号链接..."
                cmd_path=$(readlink -f "$cmd_path" 2>/dev/null || readlink "$cmd_path")
            fi
            # 从 bin/opencode 反推 node_modules 路径
            if [[ "$cmd_path" == */bin/* ]]; then
                local pkg_dir
                pkg_dir=$(dirname "$(dirname "$cmd_path")")
                # pkg_dir 可能是 .../node_modules/opencode-ai 或 .../node_modules/包名
                if [[ -f "$pkg_dir/package.json" ]]; then
                    log_debug "通过命令路径找到安装路径：$pkg_dir"
                    echo "$pkg_dir"
                    return 0
                fi
            fi
        fi
    fi
    
    # 尝试全命令名
    if [[ -n "$full_cmd_name" ]]; then
        log_debug "尝试通过全命令名$full_cmd_name查找路径..."
        local full_cmd_path=$(command -v "$full_cmd_name" 2>/dev/null)
        log_debug "全命令名$full_cmd_name路径：${full_cmd_path:-未找到}"
        if [[ -n "$full_cmd_path" ]]; then
            if [[ -L "$full_cmd_path" ]]; then
                log_debug "解析符号链接..."
                full_cmd_path=$(readlink -f "$full_cmd_path" 2>/dev/null || readlink "$full_cmd_path")
            fi
            if [[ "$full_cmd_path" == */bin/* ]]; then
                local pkg_dir
                pkg_dir=$(dirname "$(dirname "$full_cmd_path")")
                if [[ -f "$pkg_dir/package.json" ]]; then
                    log_debug "通过全命令名路径找到安装路径：$pkg_dir"
                    echo "$pkg_dir"
                    return 0
                fi
            fi
        fi
    fi

    # 方法 2: 通过包管理器 list 命令查找
    log_debug "尝试通过包管理器命令查找安装路径..."
    # 检查npm
    if command -v npm &>/dev/null; then
        local npm_path=$(npm list -g "$pkg" --parseable 2>/dev/null | head -1)
        if [[ -n "$npm_path" && -f "$npm_path/package.json" ]]; then
            log_debug "通过npm找到安装路径：$npm_path"
            echo "$npm_path"
            return 0
        fi
    fi

    # 检查pnpm
    if command -v pnpm &>/dev/null; then
        local pnpm_path=$(pnpm list -g "$pkg" --parseable 2>/dev/null | head -1)
        if [[ -n "$pnpm_path" && -f "$pnpm_path/package.json" ]]; then
            log_debug "通过pnpm找到安装路径：$pnpm_path"
            echo "$pnpm_path"
            return 0
        fi
    fi

    # 检查yarn
    if command -v yarn &>/dev/null; then
        local yarn_path=$(yarn global list --pattern "$pkg" --parseable 2>/dev/null | head -1)
        if [[ -n "$yarn_path" && -f "$yarn_path/package.json" ]]; then
            log_debug "通过yarn找到安装路径：$yarn_path"
            echo "$yarn_path"
            return 0
        fi
    fi

    # 方法 3: 搜索常见全局安装目录
    log_debug "尝试搜索常见安装目录..."
    local search_dirs=(
        "$HOME/.local/lib/node_modules/$pkg"
        "$HOME/.nvm/versions/node/*/lib/node_modules/$pkg"
        "$HOME/.fnm/node-versions/*/lib/node_modules/$pkg"
        "$HOME/.bun/install/global/node_modules/$pkg"
        "$HOME/.local/share/pnpm/global/*/node_modules/$pkg"
        "/usr/local/lib/node_modules/$pkg"
        "/usr/lib/node_modules/$pkg"
    )

    for dir_pattern in "${search_dirs[@]}"; do
        # 使用通配符匹配多个版本
        local matching_dirs=()
        # 临时启用nullglob处理空匹配
        local old_nullglob=$(shopt -p nullglob || true)
        shopt -s nullglob
        matching_dirs=($dir_pattern)
        # 恢复原来的设置
        eval "$old_nullglob" 2>/dev/null || true
        for dir in "${matching_dirs[@]}"; do
            if [[ -d "$dir" && -f "$dir/package.json" ]]; then
                log_debug "通过目录搜索找到安装路径：$dir"
                echo "$dir"
                return 0
            fi
        done
    done

    # 所有方法都没找到
    log_debug "未找到$pkg的安装路径"
    echo ""
    return 1
}

main() {
    echo ""
}

# 获取包管理器的全局根目录
get_global_root() {
    local pm="$1"
    case "$pm" in
        pnpm) pnpm root -g 2>/dev/null ;;
        yarn) yarn global dir 2>/dev/null ;;
        bun)  echo "$HOME/.bun/install/global/node_modules" ;;
        *)    npm root -g 2>/dev/null ;;
    esac
}

get_local_version() {
    local pkg="$1"
    
    # 优先级最高：直接从运行的命令获取版本（最准确）
    local cmd_name=""
    local full_cmd_name=""
    [[ "$pkg" == "opencode-ai" ]] && cmd_name="opencode"
    [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]] && cmd_name="omo" && full_cmd_name="oh-my-opencode"
    
    if [[ -n "$cmd_name" ]]; then
        # 尝试短命令
        local cmd_path=$(command -v "$cmd_name" 2>/dev/null)
        if [[ -x "$cmd_path" ]]; then
            local cmd_version
            # 合并stderr和stdout，支持版本输出到stderr的情况，支持带v前缀的版本号
            cmd_version=$($cmd_name --version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/^v//')
            if [[ -n "$cmd_version" ]]; then
                echo "$cmd_version"
                return
            fi
            # 尝试用-v参数获取版本
            cmd_version=$($cmd_name -v 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/^v//')
            if [[ -n "$cmd_version" ]]; then
                echo "$cmd_version"
                return
            fi
        fi
        # 尝试全命令（针对OMO）
        if [[ -n "$full_cmd_name" ]]; then
            local full_cmd_path=$(command -v "$full_cmd_name" 2>/dev/null)
            if [[ -x "$full_cmd_path" ]]; then
                local cmd_version
                cmd_version=$($full_cmd_name --version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/^v//')
                [[ -n "$cmd_version" ]] && echo "$cmd_version" && return
                cmd_version=$($full_cmd_name -v 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/^v//')
                [[ -n "$cmd_version" ]] && echo "$cmd_version" && return
            fi
        fi
    fi

    # 二级检测：命令不在PATH里，主动搜索常见全局安装路径（性能优先，只搜几个最常见路径）
    local npm_global_bin="$(npm prefix -g 2>/dev/null)/bin"
    local nvm_current_bin=""
    local fnm_current_bin=""
    if [[ -d "$NVM_DIR/versions/node" ]]; then
        nvm_current_bin="$(ls -d $NVM_DIR/versions/node/*/bin 2>/dev/null | sort -V | tail -1)"
    fi
    # fnm 支持
    if command -v fnm &>/dev/null; then
        fnm_current_bin="$(fnm current 2>/dev/null)/bin"
    elif [[ -d "$HOME/.fnm" ]]; then
        fnm_current_bin="$HOME/.fnm/node-versions/$(ls -t $HOME/.fnm/node-versions/ 2>/dev/null | head -1)/bin"
    fi
    local search_paths=(
        # 优先搜OMO
        "$npm_global_bin/oh-my-opencode"
        "$nvm_current_bin/oh-my-opencode"
        "$fnm_current_bin/oh-my-opencode"
        "$HOME/.local/lib/node_modules/oh-my-opencode/bin/oh-my-opencode"
        "$HOME/.bun/bin/oh-my-opencode"
        "$HOME/.local/share/pnpm/oh-my-opencode"
        # 再搜OpenCode
        "$npm_global_bin/opencode"
        "$nvm_current_bin/opencode"
        "$fnm_current_bin/opencode"
        "$HOME/.local/lib/node_modules/opencode/bin/opencode"
        "$HOME/.bun/bin/opencode"
        "$HOME/.local/share/pnpm/opencode"
    )
    
    for search_path in "${search_paths[@]}"; do
        if [[ -x "$search_path" ]]; then
            local cmd_version
            cmd_version=$($search_path --version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/^v//')
            if [[ -n "$cmd_version" ]]; then
                # 检测到安装但不在PATH里，把路径缓存到全局变量，后面提示用户
                if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]]; then
                    export OMO_NOT_IN_PATH="$search_path"
                else
                    export OC_NOT_IN_PATH="$search_path"
                fi
                echo "$cmd_version"
                return
            fi
        fi
    done
    
    # 三级检测：搜索包目录里的package.json（更快，不遍历）
    local npm_root="$(npm root -g 2>/dev/null)"
    local nvm_current_root=""
    local fnm_current_root=""
    if [[ -d "$NVM_DIR/versions/node" ]]; then
        nvm_current_root="$(ls -d $NVM_DIR/versions/node/*/lib/node_modules 2>/dev/null | sort -V | tail -1)"
    fi
    # fnm 支持
    if command -v fnm &>/dev/null; then
        fnm_current_root="$(fnm current 2>/dev/null)/lib/node_modules"
    elif [[ -d "$HOME/.fnm/node-versions" ]]; then
        fnm_current_root="$HOME/.fnm/node-versions/$(ls -t $HOME/.fnm/node-versions/ 2>/dev/null | head -1)/lib/node_modules"
    fi
    local pkg_paths=(
        "$npm_root/$pkg/package.json"
        "$nvm_current_root/$pkg/package.json"
        "$fnm_current_root/$pkg/package.json"
        "$HOME/.local/lib/node_modules/$pkg/package.json"
        "$HOME/.bun/install/global/node_modules/$pkg/package.json"
        "$HOME/.local/share/pnpm/global/5/node_modules/$pkg/package.json"
    )
    
    for pkg_json in "${pkg_paths[@]}"; do
        if [[ -f "$pkg_json" ]]; then
            local pkg_version=$(grep '"version"' "$pkg_json" | head -1 | sed 's/.*"version": *"\([^"]*\)".*/\1/' | sed 's/^v//')
            if [[ -n "$pkg_version" && "$pkg_version" != "null" ]]; then
                # 缓存路径用于提示
                if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]]; then
                    export OMO_PKG_FOUND="$pkg_json"
                else
                    export OC_PKG_FOUND="$pkg_json"
                fi
                echo "$pkg_version"
                return
            fi
        fi
    done
    
    # 所有检测都失败，返回未安装
    echo "not-installed"
}

get_remote_version() {
    local pkg="$1"
    
    # 第一步：优先用国内npmmirror公开API获取版本，不需要本地npm，速度快
    log_debug "尝试通过npmmirror获取$pkg最新版本..."
    local version=""
    version=$(curl -s --max-time 10 "https://registry.npmmirror.com/${pkg}/latest" | head -n 20 | grep -E '"version"[[:space:]]*:' | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/' | sed 's/^v//' | head -n 1)
    if [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        log_debug "npmmirror获取版本成功：v$version"
        echo "$version"
        return 0
    fi
    
    # 第二步：如果是OMO，尝试新旧两个包名
    if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]]; then
        local other_pkg=$([ "$pkg" == "$OMO_PKG_OLD" ] && echo "$OMO_PKG_NEW" || echo "$OMO_PKG_OLD")
        log_debug "尝试OMO备用包名$other_pkg..."
        version=$(curl -s --max-time 10 "https://registry.npmmirror.com/${other_pkg}/latest" | head -n 20 | grep -E '"version"[[:space:]]*:' | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/' | sed 's/^v//' | head -n 1)
        if [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            log_debug "npmmirror获取OMO备用包名版本成功：v$version"
            echo "$version"
            return 0
        fi
    fi
    
    # 第三步：fallback到GitHub的VERSION文件，走代理
    log_debug "npmmirror获取失败，尝试通过GitHub获取版本..."
    local repo=""
    [[ "$pkg" == "opencode-ai" ]] && repo="$OC_REPO"
    [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]] && repo="$OMO_REPO"
    if [[ -n "$repo" ]]; then
        # 使用get_url函数自动走代理
        version=$(get_url "https://raw.githubusercontent.com/${repo}/main/VERSION" | head -n 1 | tr -d '[:space:]' | sed 's/^v//')
        if [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            log_debug "GitHub获取版本成功：v$version"
            echo "$version"
            return 0
        fi
    fi
    
    # 第四步：如果本地有npm，尝试用npm view命令获取
    if command -v npm &>/dev/null; then
        log_debug "尝试通过npm获取版本..."
        # npm参数：15秒超时，不输出多余日志
        local npm_args="--fetch-timeout=15000 --no-audit --no-fund $([ -n "$NPM_REGISTRY" ] && echo "--registry=$NPM_REGISTRY")"
        version=$(run_with_retry --retries 2 --timeout 20 npm view "$pkg" version $npm_args 2>/dev/null)
        if [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            log_debug "npm获取版本成功：v$version"
            echo "$version"
            return 0
        fi
        
        # OMO特殊处理：尝试另一个包名
        if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]]; then
            local other_pkg=$([ "$pkg" == "$OMO_PKG_OLD" ] && echo "$OMO_PKG_NEW" || echo "$OMO_PKG_OLD")
            version=$(run_with_retry --retries 2 --timeout 20 npm view "$other_pkg" version $npm_args 2>/dev/null)
            if [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
                log_debug "npm获取OMO备用包名版本成功：v$version"
                echo "$version"
                return 0
            fi
        fi
    fi
    
    # 所有方法都失败
    log_debug "所有版本获取方式都失败"
    echo "unknown"
    return 1
}

# 带重试获取远程版本
get_remote_version_with_retry() {
    local pkg="$1"
    # 最多重试2次，间隔1秒
    for ((i=0; i<2; i++)); do
        local ver=$(get_remote_version "$pkg")
        # 校验版本号格式，必须符合x.y.z或者vx.y.z
        if [[ "$ver" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            # 去掉版本号前缀的v
            echo "${ver#v}"
            return 0
        fi
        [[ $i -lt 1 ]] && sleep 1
    done
    echo "unknown"
    return 1
}

needs_update() {
    local local_ver="$1" remote_ver="$2"
    # 远程版本获取失败时，返回2表示无法确定，避免误报和误导
    [[ "$remote_ver" == "unknown" ]] && return 2
    # 本地未安装，肯定需要更新
    [[ "$local_ver" == "not-installed" ]] && return 0
    # 去掉本地版本号前缀的v
    local_ver="${local_ver#v}"
    # 语义化版本比较：使用sort -V判断remote_ver是否大于local_ver
    local higher_ver=$(printf "%s\n%s" "$local_ver" "$remote_ver" | sort -V | tail -n1)
    [[ "$higher_ver" != "$local_ver" ]] && return 0 || return 1
}

get_changelog() {
    local repo="$1"
    # 临时禁用 set -e，防止命令失败导致脚本退出
    local set_e_state=false
    [[ $- == *e* ]] && set_e_state=true
    set +e

    # 方法 1: 使用 gh CLI
    if command -v gh &> /dev/null; then
        # Check if logged in
        if gh auth status &>/dev/null; then
            # 尝试获取 release
            local body
            body=$(gh release view --repo "$repo" --json body 2>&1)
            if [[ $? -eq 0 ]]; then
                body=$(echo "$body" | jq -r '.body // empty' 2>/dev/null)
                if [[ -n "$body" ]]; then
                    echo "$body" | head -20
                    $set_e_state && set -e
                    return
                fi
            fi
            # 尝试获取 commits
            local commits
            commits=$(gh api "repos/$repo/commits" -q '.[:8] | .[] | "• \(.commit.message | split("\n")[0])"' 2>/dev/null)
            if [[ $? -eq 0 && -n "$commits" ]]; then
                echo "$commits"
                $set_e_state && set -e
                return
            fi
        fi
    fi

    # 方法 2: 使用 curl + GitHub API（无需认证）
    if command -v curl &> /dev/null; then
        # 优先尝试直接访问 GitHub API（不使用代理），失败再使用代理
        local api_urls=(
            "https://api.github.com/repos/$repo/releases/latest"
            "${GITHUB_PROXY}https://api.github.com/repos/$repo/releases/latest"
        )

        for api_url in "${api_urls[@]}"; do
            log_debug "尝试获取 changelog: $api_url"
            local release_json
            release_json=$(curl -s --connect-timeout 5 -m 10 "$api_url" 2>/dev/null)

            # 检查是否返回有效JSON（不是错误消息）
            if [[ -n "$release_json" && "$release_json" != "{"*'"message"'* && "$release_json" != "Not Found"* ]]; then
                local body
                if command -v jq &> /dev/null; then
                    body=$(echo "$release_json" | jq -r '.body // empty' 2>/dev/null)
                else
                    body=$(echo "$release_json" | grep -o '"body"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/"body"[[:space:]]*:[[:space:]]*//; s/^"//; s/"$//' | head -1)
                fi
                if [[ -n "$body" && "$body" != "null" ]]; then
                    echo "$body" | head -20
                    $set_e_state && set -e
                    return
                fi
            fi
        done

        # 如果 release 失败，尝试获取最近 commits
        local commits_urls=(
            "https://api.github.com/repos/$repo/commits?per_page=8"
            "${GITHUB_PROXY}https://api.github.com/repos/$repo/commits?per_page=8"
        )

        for commits_url in "${commits_urls[@]}"; do
            log_debug "尝试获取 commits: $commits_url"
            local commits_json
            commits_json=$(curl -s --connect-timeout 5 -m 10 "$commits_url" 2>/dev/null)

            if [[ -n "$commits_json" && "$commits_json" != "{"*'"message"'* && "$commits_json" != "Not Found"* ]]; then
                if command -v jq &> /dev/null; then
                    local commits_output
                    commits_output=$(echo "$commits_json" | jq -r '.[] | "• \(.commit.message | split("\n")[0])"' 2>/dev/null)
                    if [[ -n "$commits_output" ]]; then
                        echo "$commits_output"
                        $set_e_state && set -e
                        return
                    fi
                else
                    # 简单解析 commit messages
                    echo "$commits_json" | grep -o '"message"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/"message"[[:space:]]*:[[:space:]]*//; s/^"//; s/"$//' | head -8 | while read -r line; do
                        echo "• $line"
                    done
                    $set_e_state && set -e
                    return
                fi
            fi
        done
    fi

    # 恢复 set -e 状态
    $set_e_state && set -e
    echo "  (更新日志获取失败，请访问 GitHub 查看)"
}

update_package() {
    local pkg="$1" name="$2" expected_ver="$3"
    echo -e "${CYAN}正在更新 $name 到 $expected_ver...${NC}"
    
    # 尝试加载nvm环境（解决非交互式shell下nvm不自动加载的问题）
    load_nvm() {
        # 常见的nvm安装路径
        local nvm_paths=(
            "$HOME/.nvm/nvm.sh"
            "$HOME/.config/nvm/nvm.sh"
            "/usr/local/nvm/nvm.sh"
            "/opt/nvm/nvm.sh"
        )
        
        for nvm_path in "${nvm_paths[@]}"; do
            if [[ -f "$nvm_path" ]]; then
                log_debug "加载nvm环境：$nvm_path"
                # 加载nvm，静默输出
                source "$nvm_path" >/dev/null 2>&1 || true
                # 加载nvm bash_completion（可选）
                [[ -f "${nvm_path%/*}/bash_completion" ]] && source "${nvm_path%/*}/bash_completion" >/dev/null 2>&1 || true
                
                # 尝试使用默认node版本
                if command -v nvm &>/dev/null; then
                    log_debug "使用nvm加载默认Node版本"
                    nvm use default >/dev/null 2>&1 || nvm use stable >/dev/null 2>&1 || true
                fi
                
                # 验证是否成功加载到npm
                if command -v npm &>/dev/null; then
                    log_debug "nvm加载成功，npm版本：$(npm --version 2>/dev/null || echo '未知')"
                    return 0
                fi
            fi
        done
        log_debug "未找到nvm环境或加载失败"
        return 1
    }
    # 先尝试加载nvm环境
    load_nvm
    
    # 检测包管理器
    local pm
    pm=$(detect_package_manager "$pkg")
    echo -e "  ${BLUE}检测到包管理器: $pm${NC}"
    
    # 查找当前安装路径
    local pkg_path
    pkg_path=$(find_package_path "$pkg")
    
    local install_cmd=""
    local success=true
    
    case "$pm" in
        pnpm)
            if [[ -n "$pkg_path" ]]; then
                # pnpm 全局更新
                install_cmd="pnpm update -g $pkg"
            else
                install_cmd="pnpm add -g $pkg"
            fi
            ;;
        yarn)
            install_cmd="yarn global add $pkg"
            ;;
        bun)
            install_cmd="bun add -g $pkg"
            ;;
        npm|*)
            # npm: 需要确定安装位置
            if [[ -n "$pkg_path" ]]; then
                # 从包路径提取安装根目录
                local install_root
                install_root=$(dirname "$pkg_path")
                
                # 检查是否是 ~/.local 或其他需要 --prefix 的位置
                if [[ "$install_root" == "$HOME/.local/lib/node_modules" ]]; then
                    install_cmd="npm install --prefix $HOME/.local -g $pkg"
                elif [[ "$install_root" == *"/.bun/"* ]]; then
                    # bun 管理的，用 bun 更新
                    install_cmd="bun update -g $pkg"
                    pm="bun"
                else
                    # NVM 或系统级，直接 npm install -g
                    install_cmd="npm install -g $pkg"
                fi
            else
                # 未安装，使用默认全局安装
                install_cmd="npm install -g $pkg"
            fi
            ;;
    esac
    
    local install_success=false
    local attempt_pkg="$pkg"
    local max_attempts=1
    # OMO双包名重试机制：自动尝试新旧两个包名，保证更新成功率
    if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]]; then
        max_attempts=2
    fi
    
    for ((attempt=0; attempt<max_attempts; attempt++)); do
        echo -e "  ${BLUE}执行: $install_cmd${NC}"
        if eval "$install_cmd" 2>&1; then
            install_success=true
            break
        elif [[ $attempt -eq 0 && $max_attempts -eq 2 ]]; then
            # 第一次失败，切换到备用包名重试
            local other_pkg
            if [[ "$attempt_pkg" == "$OMO_PKG_OLD" ]]; then
                other_pkg="$OMO_PKG_NEW"
            else
                other_pkg="$OMO_PKG_OLD"
            fi
            echo -e "${YELLOW}  包名 $attempt_pkg 安装失败，自动尝试备用包名 $other_pkg${NC}"
            # 替换install_cmd中的包名
            install_cmd=${install_cmd//$attempt_pkg/$other_pkg}
            attempt_pkg="$other_pkg"
            pkg="$other_pkg" # 更新pkg变量用于后续校验
        fi
    done
    
    if [[ "$install_success" == true ]]; then
        # 验证更新
        sleep 1  # 等待文件系统同步
        local actual_ver
        if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]]; then
            # OMO优先用omo命令直接获取版本，更准确
            actual_ver=$(omo --version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/^v//' || get_local_version "$pkg")
        else
            actual_ver=$(get_local_version "$pkg")
        fi
        
        if [[ "$actual_ver" == "$expected_ver" ]]; then
            echo -e "${GREEN}✓ $name 更新成功 (v$actual_ver)${NC}"
        else
            echo -e "${YELLOW}⚠ 更新完成，但版本验证失败${NC}"
            echo -e "  预期: $expected_ver, 实际: $actual_ver"
            echo -e "  可能需要重新登录或运行 'hash -r' 刷新 PATH 缓存"
            success=false
        fi
    else
        echo -e "${RED}✗ $name 更新失败${NC}"
        return 1
    fi
    
    # 显示实际使用的 opencode 路径
    if [[ "$pkg" == "opencode-ai" ]]; then
        local actual_path
        actual_path=$(command -v opencode 2>/dev/null)
        if [[ -n "$actual_path" ]]; then
            echo -e "  ${BLUE}当前 opencode 路径: $actual_path${NC}"
        fi
    fi
    
    # 对于Oh-My-OpenCode，自动创建omo软链接（无需用户修改环境）
    if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]] && [[ "$success" == true ]]; then
        local omo_pkg_path
        omo_pkg_path=$(find_package_path "$OMO_PKG")
        if [[ -n "$omo_pkg_path" && -f "$omo_pkg_path/bin/oh-my-opencode.js" ]]; then
            # 找到当前包管理器的全局bin目录
            local bin_dir=""
            case "$pm" in
                pnpm)
                    bin_dir="$PNPM_HOME"
                    ;;
                npm)
                    bin_dir=$(npm config get prefix 2>/dev/null | sed 's/$/\/bin/')
                    ;;
                yarn)
                    bin_dir=$(yarn global bin 2>/dev/null)
                    ;;
                bun)
                    bin_dir="$HOME/.bun/bin"
                    ;;
            esac
            
            # 创建软链接
            if [[ -n "$bin_dir" && -d "$bin_dir" ]]; then
                ln -sf "$omo_pkg_path/bin/oh-my-opencode.js" "$bin_dir/oh-my-opencode"
                ln -sf "$bin_dir/oh-my-opencode" "$bin_dir/omo"
                chmod +x "$bin_dir/oh-my-opencode"
                echo -e "  ${BLUE}已自动创建 omo 命令软链接到 $bin_dir${NC}"
            fi
        fi
    fi
    
    [[ "$success" == true ]]
}

# ============================================
# Commands
# ============================================

show_config() {
    echo ""
    echo -e "${BOLD}当前配置${NC}"
    echo "─────────────────────────────────────"
    
    # OpenCode
    local oc_auto; oc_auto=$(get_oc_autoupdate)
    local oc_path; oc_path=$(find_package_path "$OC_PKG")
    local oc_pm; oc_pm=$(detect_package_manager "$OC_PKG")
    
    echo -e "${BOLD}OpenCode:${NC}"
    case "$oc_auto" in
        "true")   echo -e "  autoupdate: ${GREEN}true${NC}" ;;
        "false")  echo -e "  autoupdate: ${RED}false${NC}" ;;
        "notify") echo -e "  autoupdate: ${YELLOW}notify${NC}" ;;
        *)        echo -e "  autoupdate: ${BLUE}$oc_auto${NC}" ;;
    esac
    echo -e "  包管理器: ${CYAN}$oc_pm${NC}"
    if [[ -n "$oc_path" ]]; then
        echo -e "  安装路径: ${CYAN}$oc_path${NC}"
    else
        echo -e "  安装路径: ${YELLOW}未检测到${NC}"
    fi
    [[ -n "${OPENCODE_DISABLE_AUTOUPDATE:-}" ]] && echo -e "  ${YELLOW}⚠ OPENCODE_DISABLE_AUTOUPDATE 已设置${NC}"
    
    echo ""
    
    # Oh-My-OpenCode
    local omo_auto; omo_auto=$(get_omo_auto_update)
    local omo_path; omo_path=$(find_package_path "$OMO_PKG")
    local omo_pm; omo_pm=$(detect_package_manager "$OMO_PKG")
    
    echo -e "${BOLD}Oh-My-OpenCode:${NC}"
    case "$omo_auto" in
        "true")  echo -e "  auto_update: ${GREEN}true${NC}" ;;
        "false") echo -e "  auto_update: ${RED}false${NC}" ;;
        *)       echo -e "  auto_update: ${BLUE}$omo_auto${NC}" ;;
    esac
    echo -e "  包管理器: ${CYAN}$omo_pm${NC}"
    if [[ -n "$omo_path" ]]; then
        echo -e "  安装路径: ${CYAN}$omo_path${NC}"
    else
        echo -e "  安装路径: ${YELLOW}未检测到${NC}"
    fi
    if is_omo_hook_disabled; then
        echo -e "  disabled_hooks: ${RED}包含 \"auto-update-checker\"${NC}"
    else
        echo -e "  disabled_hooks: ${GREEN}不包含 \"auto-update-checker\"${NC}"
    fi
    echo ""
}

do_check() {
    local has_update=false
    local pkgs_to_update=()
    local vers_to_update=()
    local names_to_update=()
    
    echo ""
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}  📦 版本检查${NC}"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    
    # Check OC
    if [[ "$CHECK_OC" == true ]]; then
        local pkg="$OC_PKG"
        local name="$OC_NAME"
        local repo="$OC_REPO"
        echo -e "${BOLD}OpenCode${NC} ($OC_PKG)"
        echo "─────────────────────────────────────"
        
        local local_ver remote_ver
        local_ver=$(get_local_version "$OC_PKG")
        remote_ver=$(get_remote_version_with_retry "$OC_PKG")
        
        # 显示版本信息
        if [[ "$remote_ver" == "unknown" ]]; then
            echo -e "  本地: ${CYAN}$local_ver${NC}  远程: ${YELLOW}获取失败${NC}"
            export REMOTE_FETCH_FAILED=1
        else
            echo -e "  本地: ${CYAN}$local_ver${NC}  远程: ${CYAN}$remote_ver${NC}"
        fi
        
        # 检测是否安装但不在PATH，给出友好提示
        if [[ "$local_ver" != "not-installed" ]]; then
            if [[ "$pkg" == "opencode-ai" ]] && [[ -n "$OC_NOT_IN_PATH" || -n "$OC_PKG_FOUND" ]]; then
                echo -e "${YELLOW}  ⚠️  OpenCode已安装但不在当前终端PATH中${NC}"
                echo -e "    安装路径：${BLUE}${OC_NOT_IN_PATH:-$OC_PKG_FOUND%/package.json/bin}${NC}"
                echo -e "    临时生效：${YELLOW}export PATH=\"\$HOME/.bun/bin:\$HOME/.local/share/pnpm:\$PATH\"${NC}"
                echo -e "    永久生效：将上面的命令添加到~/.bashrc / ~/.zshrc配置文件中"
            fi
        fi
        
        # 分状态处理更新提示（兼容set -e，避免非0返回导致脚本退出）
        local update_status=0
        needs_update "$local_ver" "$remote_ver" || update_status=$?
        if [[ $update_status -eq 0 ]]; then
            # 确定有更新
            echo -e "${YELLOW}  🆕 有更新${NC}"
            has_update=true
            pkgs_to_update+=("$pkg")
            vers_to_update+=("$remote_ver")
            names_to_update+=("$name")
            
            if [[ "$local_ver" != "not-installed" ]]; then
                echo ""
                echo -e "${BOLD}  更新内容:${NC}"
                get_changelog "$repo" | sed 's/^/    /'
            fi
        elif [[ $update_status -eq 1 ]]; then
            # 确定是最新
            echo -e "${GREEN}  ✓ 已是最新${NC}"
        else
            # 无法确定（网络失败/版本无效）
            echo -e "${YELLOW}  ⚠️  无法检查更新，请稍后重试或手动执行 opencode upgrade 升级${NC}"
        fi
        echo ""
    fi
    
    # Check OMO
    if [[ "$CHECK_OMO" == true ]]; then
        local pkg="$OMO_PKG"
        local name="$OMO_NAME"
        local repo="$OMO_REPO"
        echo -e "${BOLD}Oh-My-OpenCode${NC} ($OMO_PKG)"
        echo "─────────────────────────────────────"
        
        local local_ver remote_ver
        local_ver=$(get_local_version "$OMO_PKG")
        remote_ver=$(get_remote_version_with_retry "$OMO_PKG")
        
        # 显示版本信息
        if [[ "$remote_ver" == "unknown" ]]; then
            echo -e "  本地: ${CYAN}$local_ver${NC}  远程: ${YELLOW}获取失败${NC}"
            export REMOTE_FETCH_FAILED=1
        else
            echo -e "  本地: ${CYAN}$local_ver${NC}  远程: ${CYAN}$remote_ver${NC}"
        fi
        
        # 检测是否安装但不在PATH，给出友好提示
        if [[ "$local_ver" != "not-installed" ]]; then
            if [[ "$pkg" == "$OMO_PKG_OLD" || "$pkg" == "$OMO_PKG_NEW" ]] && [[ -n "$OMO_NOT_IN_PATH" || -n "$OMO_PKG_FOUND" ]]; then
                echo -e "${YELLOW}  ⚠️  OMO已安装但不在当前终端PATH中${NC}"
                echo -e "    安装路径：${BLUE}${OMO_NOT_IN_PATH:-$OMO_PKG_FOUND%/package.json/bin}${NC}"
                echo -e "    临时生效：${YELLOW}export PATH=\"\$HOME/.bun/bin:\$HOME/.local/share/pnpm:\$PATH\"${NC}"
                echo -e "    永久生效：将上面的命令添加到~/.bashrc / ~/.zshrc配置文件中"
            fi
        fi
        
        # 分状态处理更新提示（兼容set -e，避免非0返回导致脚本退出）
        local update_status=0
        needs_update "$local_ver" "$remote_ver" || update_status=$?
        if [[ $update_status -eq 0 ]]; then
            # 确定有更新
            echo -e "${YELLOW}  🆕 有更新${NC}"
            has_update=true
            pkgs_to_update+=("$pkg")
            vers_to_update+=("$remote_ver")
            names_to_update+=("$name")
            
            if [[ "$local_ver" != "not-installed" ]]; then
                echo ""
                echo -e "${BOLD}  更新内容:${NC}"
                get_changelog "$repo" | sed 's/^/    /'
            fi
        elif [[ $update_status -eq 1 ]]; then
            # 确定是最新
            echo -e "${GREEN}  ✓ 已是最新${NC}"
        else
            # 无法确定（网络失败/版本无效）
            echo -e "${YELLOW}  ⚠️  无法检查更新，请稍后重试或手动执行 omo upgrade 升级${NC}"
        fi
        echo ""
    fi
    
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    # 网络异常提示
    if [[ "$REMOTE_FETCH_FAILED" == "1" ]]; then
        echo ""
        echo -e "${YELLOW}⚠️  网络异常，无法获取部分远程版本信息${NC}"
        echo -e "ℹ️  国内用户可配置淘宝npm源：export NPM_REGISTRY=https://registry.npmmirror.com"
        echo -e "ℹ️  如需自定义GitHub代理：export GITHUB_PROXY=https://your-proxy.com/"
        echo ""
    fi
    
    # Ask to update
    if [[ "$has_update" == true ]]; then
        echo ""
        echo -e "${BOLD}发现 ${#pkgs_to_update[@]} 个可更新的包${NC}"
        echo ""
        
        for i in "${!pkgs_to_update[@]}"; do
            echo -n "  更新 ${names_to_update[$i]}? [y/N] "
            read -r answer
            if [[ "$answer" =~ ^[Yy]$ ]]; then
                update_package "${pkgs_to_update[$i]}" "${names_to_update[$i]}" "${vers_to_update[$i]}"
            else
                echo -e "  ${BLUE}跳过${NC}"
            fi
        done
        echo ""
    fi
}

do_update() {
    echo ""
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}  📦 直接更新${NC}"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    
    if [[ "$CHECK_OC" == true ]]; then
        local ver; ver=$(get_remote_version_with_retry "$OC_PKG")
        update_package "$OC_PKG" "$OC_NAME" "$ver"
    fi
    
    if [[ "$CHECK_OMO" == true ]]; then
        local ver; ver=$(get_remote_version_with_retry "$OMO_PKG")
        update_package "$OMO_PKG" "$OMO_NAME" "$ver"
    fi
    echo ""
}

do_disable() {
    local target="$1"
    case "$target" in
        oc|opencode)
            echo -e "${BOLD}禁用 OpenCode 自动更新...${NC}"
            set_oc_autoupdate "false"
            echo -e "${GREEN}✓ autoupdate = false${NC}"
            ;;
        omo|oh-my-opencode)
            echo -e "${BOLD}禁用 Oh-My-OpenCode 自动更新...${NC}"
            set_omo_auto_update "false"
            add_omo_disabled_hook
            echo -e "${GREEN}✓ auto_update = false${NC}"
            echo -e "${GREEN}✓ disabled_hooks 包含 \"auto-update-checker\"${NC}"
            ;;
        all|both|"")
            echo -e "${BOLD}禁用所有自动更新...${NC}"
            set_oc_autoupdate "false"
            set_omo_auto_update "false"
            add_omo_disabled_hook
            echo -e "${GREEN}✓ 已禁用所有自动更新${NC}"
            ;;
        *)
            echo -e "${RED}Unknown: $target${NC}"
            echo "Usage: oc-update disable [oc|omo|all]"
            exit 1
            ;;
    esac
}

do_enable() {
    local target="$1"
    case "$target" in
        oc|opencode)
            echo -e "${BOLD}启用 OpenCode 自动更新...${NC}"
            set_oc_autoupdate "true"
            echo -e "${GREEN}✓ autoupdate = true${NC}"
            ;;
        omo|oh-my-opencode)
            echo -e "${BOLD}启用 Oh-My-OpenCode 自动更新...${NC}"
            set_omo_auto_update "true"
            remove_omo_disabled_hook
            echo -e "${GREEN}✓ auto_update = true${NC}"
            echo -e "${GREEN}✓ 已移除 \"auto-update-checker\" hook${NC}"
            ;;
        all|both|"")
            echo -e "${BOLD}启用所有自动更新...${NC}"
            set_oc_autoupdate "true"
            set_omo_auto_update "true"
            remove_omo_disabled_hook
            echo -e "${GREEN}✓ 已启用所有自动更新${NC}"
            ;;
        *)
            echo -e "${RED}Unknown: $target${NC}"
            echo "Usage: oc-update enable [oc|omo|all]"
            exit 1
            ;;
    esac
}

show_help() {
    cat << 'EOF'
Usage: oc-update <command> [options]

Commands:
  check [--oc|--omo]     检查更新，询问是否更新
  update [--oc|--omo]    直接更新，不询问
  disable [oc|omo|all]   禁用自动更新检查
  enable [oc|omo|all]    启用自动更新检查
  config                 显示当前配置
  version                显示当前oc-update版本号
  help                   显示帮助信息

Options:
  --oc          仅操作 OpenCode
  --omo         仅操作 Oh-My-OpenCode
  -v, --version 显示版本号
  -h, --help    显示帮助信息

Examples:
  oc-update check          # 检查所有，询问是否更新
  oc-update update         # 直接更新所有
  oc-update check --oc     # 仅检查 OpenCode
  oc-update disable all    # 禁用所有自动更新
  oc-update enable omo     # 启用 OMO 自动更新
EOF
}

# ============================================
# Main
# ============================================

main() {
    check_deps
    
    # 输出关键环境信息（DEBUG模式下）
    log_debug "=== 环境信息 ==="
    log_debug "系统架构: $ARCH"
    log_debug "是否aarch64: $IS_AARCH64"
    log_debug "当前shell: $SHELL"
    log_debug "npm默认镜像: $NPM_REGISTRY"
    log_debug "GitHub代理: $GITHUB_PROXY"
    log_debug "================"
    
    local cmd="${1:-}"
    
    # Handle version/help flags without command
    case "$cmd" in
        -v|--version|version) echo "oc-update v$VERSION"; exit 0 ;;
        -h|--help|help) show_help; exit 0 ;;
    esac
    
    # Parse global options first
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --oc)  CHECK_OMO=false; shift ;;
            --omo) CHECK_OC=false; shift ;;
            -h|--help) show_help; exit 0 ;;
            -v|--version) echo "oc-update v$VERSION"; exit 0 ;;
            *) break ;;
        esac
    done

    case "$cmd" in
        check)
            do_check
            ;;
        update)
            do_update
            ;;
        disable)
            do_disable "${1:-all}"
            ;;
        enable)
            do_enable "${1:-all}"
            ;;
        config)
            show_config
            ;;
        -h|--help|"")
            show_help
            ;;
        *)
            echo -e "${RED}Unknown command: $cmd${NC}"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
